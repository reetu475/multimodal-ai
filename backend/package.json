{
  "name": "backend",
  "version": "1.0.0",
  "description": "Backend API for Multimodal Document Analysis System",
  "private": true,
  "scripts": {
    "build": "node -e \"process.argv.splice(1, 0, 'nest'); require('@nestjs/cli/bin/nest')\" build",
    "format": "prettier --write \"src/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix"
  },
  "dependencies": {
    "@google/genai": "^2.0.0",
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.22",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.22",
    "@nestjs/platform-express": "^11.1.22",
    "bull": "^4.12.9",
    "chromadb": "^1.8.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.5",
    "fluent-ffmpeg": "^2.1.3",
    "mammoth": "^1.7.2",
    "pdf-parse": "^1.1.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.4",
    "vite": "8.0.14"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.21",
    "@nestjs/schematics": "^11.1.0",
    "@types/express": "^4.17.21",
    "@types/fluent-ffmpeg": "^2.1.24",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.12.7",
    "@types/pdf-parse": "^1.1.4",
    "typescript": "^5.4.5"
  }
}
