PORT=5000

# Google Gemini API
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001

# Redis Configuration (BullMQ)
REDIS_HOST=localhost
REDIS_PORT=6379

# ChromaDB Cloud
CHROMA_URL=https://api.trychroma.com
CHROMA_CLOUD_API_KEY=your_chroma_cloud_api_key_here
CHROMA_CLOUD_TENANT=your_chroma_cloud_tenant_here
CHROMA_CLOUD_DATABASE=your_chroma_cloud_database_here


# Local Upload Directory (fallback for storing temporary files)
UPLOAD_DIR=./uploads
